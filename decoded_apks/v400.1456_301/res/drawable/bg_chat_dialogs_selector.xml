<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/chat_dialog_selected_background_color" />
                    <corners android:topLeftRadius="30.0dp" android:bottomLeftRadius="30.0dp" />
                </shape>
            </item>
            <item android:gravity="right">
                <shape android:shape="rectangle">
                    <solid android:color="@color/chat_unread_separator_color" />
                    <size android:width="3.0dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/chat_dialog_selected_background_color" />
                    <corners android:topLeftRadius="30.0dp" android:bottomLeftRadius="30.0dp" />
                </shape>
            </item>
            <item android:gravity="right">
                <shape android:shape="rectangle">
                    <solid android:color="@color/chat_unread_separator_color" />
                    <size android:width="3.0dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
