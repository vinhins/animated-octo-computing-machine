<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="false" android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="1.0dp" />
            <solid android:color="#ebedf0" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="1.0dp" />
            <solid android:color="@color/btn_decline_pressed" />
            <stroke android:width="1.0dp" android:color="@color/btn_decline" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="1.0dp" />
            <solid android:color="@color/btn_decline_background" />
            <stroke android:width="1.0dp" android:color="@color/btn_decline" />
        </shape>
    </item>
</selector>
