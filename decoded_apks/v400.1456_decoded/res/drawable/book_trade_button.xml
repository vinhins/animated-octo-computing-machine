<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="@color/background_panel" android:endColor="@color/panel_separator" android:angle="90.0" />
        </shape>
        <shape>
            <solid android:color="@color/background_panel" />
        </shape>
    </item>
    <item android:state_pressed="false">
        <shape>
            <solid android:color="@color/background_panel" />
        </shape>
    </item>
</selector>